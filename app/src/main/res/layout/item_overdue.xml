<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#FEF2F2">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Student Name -->
        <TextView
            android:id="@+id/tvOverdueStudent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ali Khan"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#1F2937" />

        <!-- Book Title -->
        <TextView
            android:id="@+id/tvOverdueBook"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Clean Code"
            android:textSize="14sp"
            android:textColor="#6B7280" />

        <!-- Due Date -->
        <TextView
            android:id="@+id/tvOverdueDueDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Due: Mar 01, 2026"
            android:textSize="13sp"
            android:textColor="#9CA3AF" />

        <!-- Overdue Days + Fine Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvOverdueDays"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="5 days overdue"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#EF4444" />

            <TextView
                android:id="@+id/tvOverdueFine"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fine: Rs.500"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#EF4444" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>